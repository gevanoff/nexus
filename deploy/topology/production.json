{
  "schema_version": 1,
  "name": "nexus-production",
  "description": "Canonical multi-host production placement for ai1, ai2, and ada2.",
  "defaults": {
    "repo_dir_by_platform": {
      "macos": "/Users/ai/ai/nexus",
      "linux": "/home/ai/ai/nexus"
    },
    "env": {
      "VLLM_MODEL_STRONG": "Qwen/Qwen2.5-7B-Instruct",
      "VLLM_MODEL_FAST": "Qwen/Qwen2.5-3B-Instruct",
      "VLLM_MODEL_DEFAULT": "Qwen/Qwen2.5-7B-Instruct",
      "VLLM_MODEL_EMBEDDINGS": "BAAI/bge-small-en-v1.5",
      "VLLM_GPU_MEMORY_UTILIZATION": "0.35",
      "VLLM_MAX_MODEL_LEN": "8192",
      "VLLM_FAST_GPU_MEMORY_UTILIZATION": "0.25",
      "VLLM_FAST_MAX_MODEL_LEN": "8192",
      "VLLM_EMBEDDINGS_GPU_MEMORY_UTILIZATION": "0.10",
      "MLX_MODEL_PATH": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_MODEL_TYPE": "lm",
      "MLX_MODEL_STRONG": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_MODEL_FAST": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_MODEL_DEFAULT": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_BASE_URL": "http://ai2:10240/v1",
      "MLX_ADVERTISE_BASE_URL": "http://ai2:10240/v1",
      "VLLM_BASE_URL": "http://ada2:8003/v1",
      "VLLM_ADVERTISE_BASE_URL": "http://ada2:8003/v1",
      "VLLM_FAST_BASE_URL": "http://ada2:8001/v1",
      "VLLM_FAST_ADVERTISE_BASE_URL": "http://ada2:8001/v1",
      "VLLM_EMBEDDINGS_BASE_URL": "http://ada2:8002/v1",
      "VLLM_EMBEDDINGS_ADVERTISE_BASE_URL": "http://ada2:8002/v1",
      "VLLM_PORT": "8003",
      "IMAGES_BACKEND": "http_openai_images",
      "IMAGES_BACKEND_CLASS": "gpu_heavy",
      "IMAGES_HTTP_BASE_URL": "http://ada2:7860",
      "IMAGES_ADVERTISE_BASE_URL": "http://ada2:7860",
      "IMAGES_SHIM_INVOKEAI_BASE_URL": "http://invokeai:9090",
      "INVOKEAI_BASE_URL": "http://ada2:9090",
      "INVOKEAI_ADVERTISE_BASE_URL": "http://ada2:9090",
      "SDXL_TURBO_BASE_URL": "http://ada2:9050",
      "SDXL_TURBO_ADVERTISE_BASE_URL": "http://ada2:9050",
      "LIGHTON_OCR_API_BASE_URL": "http://ada2:9155",
      "LIGHTON_OCR_ADVERTISE_BASE_URL": "http://ada2:9155",
      "PERSONAPLEX_BASE_URL": "http://ada2:9160",
      "PERSONAPLEX_ADVERTISE_BASE_URL": "http://ada2:9160",
      "FOLLOWYOURCANVAS_BASE_URL": "http://ada2:9165",
      "FOLLOWYOURCANVAS_ADVERTISE_BASE_URL": "http://ada2:9165",
      "SKYREELS_V2_BASE_URL": "http://ada2:9180",
      "SKYREELS_V2_ADVERTISE_BASE_URL": "http://ada2:9180",
      "HEARTMULA_BASE_URL": "http://ada2:9185",
      "HEARTMULA_ADVERTISE_BASE_URL": "http://ada2:9185",
      "POCKET_TTS_BASE_URL": "http://ai2:9940",
      "POCKET_TTS_ADVERTISE_BASE_URL": "http://ai2:9940",
      "LUXTTS_BASE_URL": "http://ai2:9170",
      "LUXTTS_ADVERTISE_BASE_URL": "http://ai2:9170",
      "QWEN3_TTS_BASE_URL": "http://ai2:9175",
      "QWEN3_TTS_ADVERTISE_BASE_URL": "http://ai2:9175",
      "MEDIAMTX_HLS_PORT": "8891",
      "MEDIAMTX_ADVERTISE_BASE_URL": "http://ai1:8891",
      "MEDIAMTX_API_ADVERTISE_URL": "http://ai1:9997",
      "MEDIAMTX_WEBRTC_ADDITIONAL_HOSTS": "ai1",
      "DEFAULT_BACKEND": "local_mlx",
      "EMBEDDINGS_BACKEND": "local_vllm_embeddings",
      "TRANSCRIPTION_BACKEND_CLASS": "local_mlx",
      "ROUTER_ENABLE_POLICY": "true",
      "ETCD_PREFIX": "/nexus/services/",
      "NEXUS_REGISTRATION_INTERVAL_SEC": "30",
      "NEXUS_REGISTRATION_TIMEOUT_SEC": "5",
      "NEXUS_REGISTRATION_LEASE_TTL_SEC": "90"
    }
  },
  "hosts": {
    "ai1": {
      "description": "Media ingress and spare Linux/NVIDIA capacity.",
      "platform": "linux",
      "ssh_target": "ai@ai1",
      "components": [
        "mediamtx"
      ],
      "env": {
        "ETCD_URL": "http://ai2:2379"
      }
    },
    "ai2": {
      "description": "Gateway, control plane, containerized TTS, and host-native MLX reasoning.",
      "platform": "macos",
      "ssh_target": "ai@ai2",
      "components": [
        "gateway",
        "etcd",
        "tts",
        "luxtts"
      ],
      "native_services": [
        "mlx"
      ],
      "env": {
        "ETCD_URL": "http://etcd:2379",
        "MLX_BASE_URL": "http://ai2:10240/v1",
        "MLX_ADVERTISE_BASE_URL": "http://ai2:10240/v1",
        "LUXTTS_UPSTREAM_BASE_URL": "http://qwen3-tts:9175",
        "LUXTTS_PROMPT_AUDIO": "/var/lib/tts_refs/Gabriel4_dbf8a412dcaf.wav",
        "QWEN3_TTS_DEVICE_MAP": "auto",
        "QWEN3_TTS_DTYPE": "float16",
        "QWEN3_TTS_ATTN_IMPL": "sdpa",
        "UI_IP_ALLOWLIST": "127.0.0.1,172.28.0.1,10.10.22.0/24",
        "DISABLED_BACKEND_CLASSES": "followyourcanvas,heartmula_music,personaplex",
        "DEFAULT_BACKEND": "local_mlx"
      }
    },
    "ada2": {
      "description": "GPU-bound vLLM plus heavy image and video generation services.",
      "platform": "linux",
      "ssh_target": "ai@ada2",
      "components": [
        "images",
        "invokeai",
        "sdxl-turbo",
        "lighton-ocr",
        "skyreels-v2",
        "vllm"
      ],
      "env": {
        "ETCD_URL": "http://ai2:2379",
        "IMAGES_SHIM_MODE": "invokeai_queue",
        "SDXL_TURBO_ENABLE_MODEL_CPU_OFFLOAD": "true"
      }
    }
  }
}
