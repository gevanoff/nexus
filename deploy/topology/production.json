{
  "schema_version": 1,
  "name": "nexus-production",
  "description": "Canonical multi-host production placement for ai1, ai2, and ada2.",
  "defaults": {
    "repo_dir_by_platform": {
      "macos": "/Users/ai/ai/nexus",
      "linux": "/home/ai/ai/nexus"
    },
    "env": {
      "VLLM_MODEL_STRONG": "unsloth/Qwen3-30B-A3B-FP8",
      "VLLM_MODEL_FAST": "unsloth/Qwen3-30B-A3B-GGUF:Q4_K_M",
      "VLLM_MODEL_DEFAULT": "unsloth/Qwen3-30B-A3B-FP8",
      "VLLM_MODEL_EMBEDDINGS": "unsloth/Qwen3-Embedding-4B",
      "VLLM_GPU_MEMORY_UTILIZATION": "0.72",
      "VLLM_MAX_MODEL_LEN": "8192",
      "VLLM_FAST_GPU_MEMORY_UTILIZATION": "0.65",
      "VLLM_FAST_MAX_MODEL_LEN": "8192",
      "VLLM_EMBEDDINGS_GPU_MEMORY_UTILIZATION": "0.70",
      "VLLM_EMBEDDINGS_MAX_MODEL_LEN": "2048",
      "MLX_MODEL_PATH": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_MODEL_TYPE": "lm",
      "MLX_MODEL_STRONG": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_MODEL_FAST": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_MODEL_DEFAULT": "mlx-community/Qwen3-30B-A3B-4bit",
      "MLX_BASE_URL": "http://ai2:10240/v1",
      "MLX_ADVERTISE_BASE_URL": "http://ai2:10240/v1",
      "VLLM_BASE_URL": "http://ada2:8003/v1",
      "VLLM_ADVERTISE_BASE_URL": "http://ada2:8003/v1",
      "VLLM_FAST_BASE_URL": "http://ai1:8001/v1",
      "VLLM_FAST_ADVERTISE_BASE_URL": "http://ai1:8001/v1",
      "VLLM_EMBEDDINGS_BASE_URL": "http://ai1:8002/v1",
      "VLLM_EMBEDDINGS_ADVERTISE_BASE_URL": "http://ai1:8002/v1",
      "VLLM_PORT": "8003",
      "IMAGES_BACKEND": "http_openai_images",
      "IMAGES_BACKEND_CLASS": "gpu_heavy",
      "IMAGES_HTTP_BASE_URL": "http://ada2:7860",
      "IMAGES_ADVERTISE_BASE_URL": "http://ada2:7860",
      "IMAGES_SHIM_INVOKEAI_BASE_URL": "http://invokeai:9090",
      "INVOKEAI_BASE_URL": "http://ada2:9090",
      "INVOKEAI_ADVERTISE_BASE_URL": "http://ada2:9090",
      "SDXL_TURBO_BASE_URL": "http://ai1:9050",
      "SDXL_TURBO_ADVERTISE_BASE_URL": "http://ai1:9050",
      "LIGHTON_OCR_API_BASE_URL": "http://ada2:9155",
      "LIGHTON_OCR_ADVERTISE_BASE_URL": "http://ada2:9155",
      "PERSONAPLEX_BASE_URL": "http://ada2:9160",
      "PERSONAPLEX_ADVERTISE_BASE_URL": "http://ada2:9160",
      "FOLLOWYOURCANVAS_BASE_URL": "http://ada2:9165",
      "FOLLOWYOURCANVAS_ADVERTISE_BASE_URL": "http://ada2:9165",
      "SKYREELS_V2_BASE_URL": "http://ada2:9180",
      "SKYREELS_V2_ADVERTISE_BASE_URL": "http://ada2:9180",
      "HEARTMULA_BASE_URL": "http://ada2:9185",
      "HEARTMULA_ADVERTISE_BASE_URL": "http://ada2:9185",
      "POCKET_TTS_BASE_URL": "http://ai2:9940",
      "POCKET_TTS_ADVERTISE_BASE_URL": "http://ai2:9940",
      "LUXTTS_BASE_URL": "http://ai2:9170",
      "LUXTTS_ADVERTISE_BASE_URL": "http://ai2:9170",
      "QWEN3_TTS_BASE_URL": "http://ai2:9175",
      "QWEN3_TTS_ADVERTISE_BASE_URL": "http://ai2:9175",
      "MEDIAMTX_HLS_PORT": "8891",
      "MEDIAMTX_ADVERTISE_BASE_URL": "http://ai1:8891",
      "MEDIAMTX_API_ADVERTISE_URL": "http://ai1:9997",
      "MEDIAMTX_WEBRTC_ADDITIONAL_HOSTS": "ai1",
      "DEFAULT_BACKEND": "local_mlx",
      "EMBEDDINGS_BACKEND": "local_vllm_embeddings",
      "EMBEDDINGS_MODEL": "unsloth/Qwen3-Embedding-4B",
      "TRANSCRIPTION_BACKEND_CLASS": "local_mlx",
      "ROUTER_ENABLE_POLICY": "true",
      "ETCD_PREFIX": "/nexus/services/",
      "NEXUS_REGISTRATION_INTERVAL_SEC": "30",
      "NEXUS_REGISTRATION_TIMEOUT_SEC": "5",
      "NEXUS_REGISTRATION_LEASE_TTL_SEC": "90",
      "LIFECYCLE_MANAGER_BASE_URL": "http://lifecycle-manager:9190",
      "LIFECYCLE_MANAGER_ADVERTISE_BASE_URL": "http://ai2:9190",
      "NEXUS_LIFECYCLE_MODE": "assisted"
    }
  },
  "hosts": {
    "ai1": {
      "description": "Dual-GPU Linux/NVIDIA node (RTX 3090 24GB + RTX 5060 Ti 16GB) for media ingress, SDXL-Turbo, and secondary vLLM/CUDA capacity.",
      "platform": "linux",
      "ssh_target": "ai@ai1",
      "components": [
        "mediamtx",
        "sdxl-turbo",
        "vllm-fast",
        "vllm-embeddings"
      ],
      "env": {
        "ETCD_URL": "http://ai2:2379",
        "SDXL_TURBO_DEVICE": "cuda",
        "SDXL_TURBO_CUDA_VISIBLE_DEVICES": "1",
        "SDXL_TURBO_ENABLE_MODEL_CPU_OFFLOAD": "true",
        "SDXL_TURBO_ENABLE_SEQUENTIAL_CPU_OFFLOAD": "true",
        "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True",
        "VLLM_FAST_SERVICE_NAME": "vllm-fast",
        "VLLM_FAST_BACKEND_CLASS": "local_vllm_fast",
        "VLLM_FAST_TOKENIZER": "Qwen/Qwen3-30B-A3B",
        "VLLM_FAST_GPU_MEMORY_UTILIZATION": "0.82",
        "VLLM_FAST_MAX_MODEL_LEN": "2048",
        "VLLM_FAST_CUDA_VISIBLE_DEVICES": "0",
        "VLLM_EMBEDDINGS_SERVICE_NAME": "vllm-embeddings",
        "VLLM_EMBEDDINGS_BACKEND_CLASS": "local_vllm_embeddings",
        "VLLM_EMBEDDINGS_GPU_MEMORY_UTILIZATION": "0.72",
        "VLLM_EMBEDDINGS_MAX_MODEL_LEN": "2048",
        "VLLM_EMBEDDINGS_CUDA_VISIBLE_DEVICES": "1"
      }
    },
    "ai2": {
      "description": "Mac M3 Ultra with 512GB unified memory for gateway/control plane, containerized TTS, and host-native MLX reasoning.",
      "platform": "macos",
      "ssh_target": "ai@ai2",
      "components": [
        "gateway",
        "etcd",
        "lifecycle-manager",
        "tts",
        "luxtts"
      ],
      "native_services": [
        "mlx"
      ],
      "env": {
        "ETCD_URL": "http://etcd:2379",
        "MLX_BASE_URL": "http://ai2:10240/v1",
        "MLX_ADVERTISE_BASE_URL": "http://ai2:10240/v1",
        "LUXTTS_UPSTREAM_BASE_URL": "http://qwen3-tts:9175",
        "LUXTTS_PROMPT_AUDIO": "/var/lib/tts_refs/Gabriel4_dbf8a412dcaf.wav",
        "QWEN3_TTS_DEVICE_MAP": "auto",
        "QWEN3_TTS_DTYPE": "float16",
        "QWEN3_TTS_ATTN_IMPL": "sdpa",
        "UI_IP_ALLOWLIST": "127.0.0.1,172.28.0.1,10.10.22.0/24",
        "DISABLED_BACKEND_CLASSES": "followyourcanvas,personaplex",
        "DEFAULT_BACKEND": "local_mlx"
      }
    },
    "ada2": {
      "description": "Linux/NVIDIA node with 128GB system RAM and an RTX 6000 Ada 48GB for primary heavy vLLM plus image and video generation services.",
      "platform": "linux",
      "ssh_target": "ai@ada2",
      "components": [
        "images",
        "invokeai",
        "lighton-ocr",
        "skyreels-v2",
        "vllm-strong"
      ],
      "env": {
        "ETCD_URL": "http://ai2:2379",
        "IMAGES_SHIM_MODE": "invokeai_queue",
        "SDXL_TURBO_ENABLE_MODEL_CPU_OFFLOAD": "true",
        "VLLM_SERVICE_NAME": "vllm",
        "VLLM_BACKEND_CLASS": "local_vllm",
        "VLLM_CPU_OFFLOAD_GB": "8",
        "VLLM_GPU_MEMORY_UTILIZATION": "0.55",
        "VLLM_MAX_MODEL_LEN": "2048"
      }
    }
  }
}
