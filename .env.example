# Nexus Configuration
# Copy this file to .env and customize for your environment

# ===== Gateway Configuration =====

# Gateway authentication token (required)
# Generate a strong random token for production
GATEWAY_BEARER_TOKEN=change-me-in-production

# Gateway ports
GATEWAY_PORT=8800
OBSERVABILITY_PORT=8801
PROXY_HTTP_PORT=8080
# PROXY_HTTPS_PORT=8443

# Gateway network binding (inside container)
GATEWAY_HOST=0.0.0.0
OBSERVABILITY_HOST=0.0.0.0

# Optional request guardrails
# MAX_REQUEST_BYTES=0 disables.
MAX_REQUEST_BYTES=10485760

# Optional: gateway-side allowlists (advanced)
IP_ALLOWLIST=
TRUST_PROXY_CIDRS=
IP_ALLOWLIST_DEBUG=false
UI_IP_ALLOWLIST=
UI_IP_ALLOWLIST_DEBUG=false
# Trust forwarded client IP headers only from these proxy CIDRs/IPs.
# Example when gateway sees Docker bridge as peer: 172.28.0.1
UI_TRUST_PROXY_CIDRS=
# UI model load tuning (smaller probe timeout + short cache for snappier UI model list)
UI_MODELS_PROBE_TIMEOUT_SEC=4
UI_MODELS_CACHE_TTL_SEC=8

# Optional multi-token auth + per-token policies
GATEWAY_BEARER_TOKENS=
GATEWAY_TOKEN_POLICIES_JSON=
GATEWAY_TOKEN_POLICIES_STRICT=true

# Telegram bot integration (docker-compose.telegram-bot.yml)
TELEGRAM_TOKEN=
TELEGRAM_GATEWAY_BASE_URL=http://gateway:8800
TELEGRAM_GATEWAY_MODEL=auto
TELEGRAM_MAX_HISTORY=20
TELEGRAM_MAX_MESSAGE=3900
TELEGRAM_LOG_LEVEL=info

# ===== Service Ports =====

# LLM inference service
OLLAMA_PORT=11434
# Default (containerized): http://ollama:11434
# Native accelerator host (same machine): http://host.docker.internal:11434
# Native accelerator host (remote Mac): http://<mac-host-or-ip>:11434
OLLAMA_BASE_URL=http://ollama:11434
MLX_BASE_URL=http://mlx:10240/v1
MLX_PORT=10240
MLX_MODEL_PATH=mlx-community/gemma-2-2b-it-8bit
MLX_MODEL_TYPE=lm

# Image generation service
IMAGES_PORT=7860

# Text-to-speech service
TTS_PORT=9940
LUXTTS_PORT=9170
QWEN3_TTS_PORT=9175

# Service discovery (etcd)
ETCD_PORT=2379
ETCD_ENABLED=true
ETCD_URL=http://etcd:2379
ETCD_PREFIX=/nexus/services/
ETCD_POLL_INTERVAL=15
ETCD_SEED_FROM_ENV=true

# ===== Image Generation Backend =====

# Options: mock, http_openai_images, http_a1111
IMAGES_BACKEND=http_openai_images

# Gateway target for OpenAI-images-compatible backend
IMAGES_HTTP_BASE_URL=http://images:7860

# Images service (OpenAI Images shim)
# stub: returns a tiny PNG (no GPU/backends required)
# invokeai_queue: proxies to an InvokeAI instance via INVOKEAI_BASE_URL
IMAGES_SHIM_MODE=stub

# Only used when IMAGES_SHIM_MODE=invokeai_queue
INVOKEAI_BASE_URL=http://invokeai:9090

# ===== Resource Configuration =====

# Enable GPU support (requires NVIDIA Docker runtime)
# Set to 'false' to run CPU-only
ENABLE_GPU=true

# Memory limits (optional)
# GATEWAY_MEMORY_LIMIT=2g
# OLLAMA_MEMORY_LIMIT=8g
# IMAGES_MEMORY_LIMIT=16g

# ===== Service Profiles =====

# Docker Compose profiles to enable
# Default: Only gateway and ollama
# Options: full, images, audio
# 
# Examples:
#   COMPOSE_PROFILES=full          # All services
#   COMPOSE_PROFILES=images,audio  # Gateway + Ollama + Images + TTS
#
COMPOSE_PROFILES=

# ===== Advanced Configuration =====

# Enable/disable metrics collection
METRICS_ENABLED=true

# Router configuration
DEFAULT_BACKEND=ollama
ROUTER_ENABLE_POLICY=true

# Memory v2 features
MEMORY_V2_ENABLED=true

# ===== Tool Bus =====

# Tool bus logs (persisted under ./.runtime/gateway/data)
TOOLS_LOG_MODE=ndjson
TOOLS_LOG_PATH=/var/lib/gateway/data/tools/invocations.jsonl
TOOLS_LOG_DIR=/var/lib/gateway/data/tools

# Tools working directory (inside container)
TOOLS_SHELL_CWD=/var/lib/gateway/data/tools_work
TOOLS_SHELL_TIMEOUT_SEC=20

# External tools registry (persisted under ./.runtime/gateway/config)
TOOLS_REGISTRY_PATH=/var/lib/gateway/config/tools_registry.json
TOOLS_REGISTRY_SHA256=

# Safe defaults: keep high-privilege tools off
TOOLS_ALLOW_SHELL=false
TOOLS_ALLOW_FS=false
TOOLS_ALLOW_HTTP_FETCH=false
TOOLS_ALLOW_GIT=false
TOOLS_ALLOW_SYSTEM_INFO=false
TOOLS_ALLOW_MODELS_REFRESH=false
TOOLS_ALLOWLIST=echo,followyourcanvas_generate,heartmula_generate,lighton_ocr,skyreels_generate

# ===== Development Options =====

# Enable hot reload for gateway (development only)
# HOT_RELOAD=true

# Logging level
# LOG_LEVEL=INFO

# ===== Data Persistence =====

# Nexus uses host bind mounts under `./.runtime/` by default.
# - Gateway RW data:   ./.runtime/gateway/data   → /var/lib/gateway/data
# - Gateway RO config: ./.runtime/gateway/config → /var/lib/gateway/config
# - Ollama models:     ./.runtime/ollama         → /root/.ollama
# - Images:            ./.runtime/images/*       → /data
# - TTS:               ./.runtime/tts/data       → /data
# - etcd:              ./.runtime/etcd/data      → /etcd-data

# If you want to relocate persistence outside the repo (recommended for servers),
# update the bind-mount sources in the relevant `docker-compose.*.yml` file.

# Shared TTS reference pool (voice clone prompts and reusable refs)
# Host path used by compose files: ./.runtime/tts_refs
LUXTTS_REFS_DIR=/var/lib/luxtts/voices
LUXTTS_SHARED_REFS_DIR=/var/lib/tts_refs
LUXTTS_SYNC_SHARED_REFS=true
LUXTTS_SYNC_OVERWRITE=false
QWEN3_TTS_REFS_DIR=/var/lib/qwen3-tts/voices
QWEN3_TTS_SHARED_REFS_DIR=/var/lib/tts_refs
QWEN3_TTS_SYNC_SHARED_REFS=true
QWEN3_TTS_SYNC_OVERWRITE=false



# ===== TTS (Pocket TTS shim) =====

# Gateway backend target (containerized default)
POCKET_TTS_BASE_URL=http://tts:9940

# Backend selection: auto | python | command
POCKET_TTS_BACKEND=auto

# Default hints
POCKET_TTS_MODEL_NAME=pocket-tts
POCKET_TTS_MODEL_PATH=
POCKET_TTS_VOICE=alba
POCKET_TTS_REFS_DIR=/var/lib/tts_refs

# Command backend (used when POCKET_TTS_BACKEND=command or when python import fails)
POCKET_TTS_COMMAND=pocket-tts


# ===== TTS (LuxTTS shim) =====

# Gateway backend target (containerized default)
LUXTTS_BASE_URL=http://luxtts:9170

# Runtime/model identifiers
LUXTTS_MODEL=luxtts
LUXTTS_OUTPUT_FORMAT=wav

# Configure ONE mode for readiness:
# 1) Proxy mode (recommended)
LUXTTS_UPSTREAM_BASE_URL=
LUXTTS_UPSTREAM_ENDPOINT=/v1/audio/speech

# 2) Subprocess mode
LUXTTS_RUN_COMMAND=python /app/app/scripts/run_luxtts.py
LUXTTS_WORKDIR=/app

LUXTTS_TIMEOUT_SEC=120
LUXTTS_READYZ_TIMEOUT_SEC=20

# Optional: map OpenAI voice names to prompt files directly
# LUXTTS_VOICE_MAP_JSON={"alloy":"/var/lib/luxtts/voices/alice.wav"}


# ===== TTS (Qwen3-TTS shim) =====

# Gateway backend target (containerized default)
QWEN3_TTS_BASE_URL=http://qwen3-tts:9175

# Runtime/model identifiers
QWEN3_TTS_MODEL=qwen3-tts
QWEN3_TTS_OUTPUT_FORMAT=wav

# Configure ONE mode for readiness:
# 1) Proxy mode (recommended)
QWEN3_TTS_UPSTREAM_BASE_URL=
QWEN3_TTS_UPSTREAM_ENDPOINT=/v1/audio/speech

# 2) Subprocess mode
QWEN3_TTS_RUN_COMMAND=python /app/app/scripts/run_qwen3_tts.py
QWEN3_TTS_WORKDIR=/app

QWEN3_TTS_TIMEOUT_SEC=300
QWEN3_TTS_READYZ_TIMEOUT_SEC=20

# Optional: map voice names to explicit reference files for clone-mode fallback
# QWEN3_TTS_REF_MAP_JSON={"alice":"/var/lib/qwen3-tts/voices/alice.wav"}
# Optional default reference transcript when using ref-map/auto-discovered refs
# QWEN3_TTS_REFS_REF_TEXT=
