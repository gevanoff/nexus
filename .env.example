# Nexus Configuration
# Copy this file to .env and customize for your environment

# ===== Gateway Configuration =====

# Gateway authentication token (required)
# Generate a strong random token for production
GATEWAY_BEARER_TOKEN=change-me-in-production

# Gateway ports
GATEWAY_PORT=8800
OBSERVABILITY_PORT=8801
PROXY_HTTP_PORT=8080
PROXY_HTTPS_PORT=443

# Gateway network binding (inside container)
GATEWAY_HOST=0.0.0.0
OBSERVABILITY_HOST=0.0.0.0
HEALTH_CHECK_INTERVAL_SEC=30
HEALTH_CHECK_TIMEOUT_SEC=10

# Optional request guardrails
# MAX_REQUEST_BYTES=0 disables.
MAX_REQUEST_BYTES=104857600

# Optional: gateway-side allowlists (advanced)
IP_ALLOWLIST=
TRUST_PROXY_CIDRS=
IP_ALLOWLIST_DEBUG=false
UI_IP_ALLOWLIST=
UI_IP_ALLOWLIST_DEBUG=false
# If the gateway is containerized and you access it directly via the published
# host port, the UI may observe the Docker bridge peer (for example 172.28.0.1)
# instead of the original browser IP unless a trusted reverse proxy injects
# forwarded headers.
# Trust forwarded client IP headers only from these proxy CIDRs/IPs.
# Example when gateway sees Docker bridge as peer: 172.28.0.1
UI_TRUST_PROXY_CIDRS=
# UI model load tuning (smaller probe timeout + short cache for snappier UI model list)
UI_MODELS_PROBE_TIMEOUT_SEC=4
UI_MODELS_CACHE_TTL_SEC=8

# Optional multi-token auth + per-token policies
GATEWAY_BEARER_TOKENS=
GATEWAY_TOKEN_POLICIES_JSON=
GATEWAY_TOKEN_POLICIES_STRICT=true

# Telegram bot integration (docker-compose.telegram-bot.yml)
TELEGRAM_TOKEN=
TELEGRAM_GATEWAY_BASE_URL=http://gateway:8800
TELEGRAM_GATEWAY_MODEL=auto
TELEGRAM_MAX_HISTORY=20
TELEGRAM_MAX_MESSAGE=3900
TELEGRAM_LOG_LEVEL=info

# ===== Service Ports =====

# Primary host roles:
# - ai2: host-native MLX for the heavyweight reasoning/coding/long-context path
# - ai1: vLLM for lightweight/fast chat plus embeddings
# - ada2: heavyweight image/video generation services
#
# vLLM services (typically ai1)
VLLM_BASE_URL=http://ai1:8000/v1
VLLM_ADVERTISE_BASE_URL=http://ai1:8000/v1
VLLM_FAST_BASE_URL=http://ai1:8001/v1
VLLM_FAST_ADVERTISE_BASE_URL=http://ai1:8001/v1
VLLM_EMBEDDINGS_BASE_URL=http://ai1:8002/v1
VLLM_EMBEDDINGS_ADVERTISE_BASE_URL=http://ai1:8002/v1
VLLM_PORT=8000
VLLM_FAST_PORT=8001
VLLM_EMBEDDINGS_PORT=8002
VLLM_MODEL_STRONG=Qwen/Qwen2.5-1.5B-Instruct
VLLM_MAX_MODEL_LEN=8192
VLLM_MODEL_FAST=Qwen/Qwen2.5-0.5B-Instruct
VLLM_FAST_MAX_MODEL_LEN=8192
VLLM_MODEL_DEFAULT=Qwen/Qwen2.5-1.5B-Instruct
VLLM_MODEL_EMBEDDINGS=BAAI/bge-small-en-v1.5

# Host-native MLX reasoning service (typically ai2)
# If Gateway is containerized on ai2 itself, host.docker.internal is also valid.
MLX_BASE_URL=http://ai2:10240/v1
MLX_ADVERTISE_BASE_URL=http://ai2:10240/v1
MLX_PORT=10240
MLX_MODEL_PATH=mlx-community/Qwen2.5-7B-Instruct-4bit
MLX_MODEL_TYPE=lm
MLX_CONFIG_PATH=/var/lib/mlx/config/config.yaml

# Image generation service
IMAGES_PORT=7860
INVOKEAI_PORT=9090
SDXL_TURBO_PORT=9050
LIGHTON_OCR_PORT=9155
PERSONAPLEX_PORT=9160
FYC_PORT=9165
SKYREELS_PORT=9180
HEARTMULA_PORT=9185
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997

# Text-to-speech service
TTS_PORT=9940
LUXTTS_PORT=9170
QWEN3_TTS_PORT=9175

# Service discovery (etcd)
ETCD_PORT=2379
ETCD_PEER_PORT=2380
ETCD_ENABLED=true
ETCD_URL=http://etcd:2379
ETCD_PREFIX=/nexus/services/
ETCD_POLL_INTERVAL=15
ETCD_SEED_FROM_ENV=true
NEXUS_REGISTRATION_INTERVAL_SEC=30
NEXUS_REGISTRATION_TIMEOUT_SEC=5
NEXUS_REGISTRATION_LEASE_TTL_SEC=90
ETCD_CONTAINER_NAME=nexus-etcd
ETCD_NAME=nexus-etcd
ETCD_LISTEN_CLIENT_URLS=http://0.0.0.0:2379
ETCD_ADVERTISE_CLIENT_URLS=http://etcd:2379
ETCD_LISTEN_PEER_URLS=http://0.0.0.0:2380
ETCD_INITIAL_ADVERTISE_PEER_URLS=http://etcd:2380
ETCD_INITIAL_CLUSTER=nexus-etcd=http://etcd:2380
ETCD_INITIAL_CLUSTER_STATE=new
ETCD_INITIAL_CLUSTER_TOKEN=nexus-etcd-cluster

# ===== Image Generation Backend =====

# Options: mock, http_openai_images, http_a1111, local_mlx
# local_mlx is accepted as an alias for the OpenAI-compatible MLX image path.
IMAGES_BACKEND=http_openai_images

# Gateway target for OpenAI-images-compatible backend
IMAGES_HTTP_BASE_URL=http://images:7860
IMAGES_ADVERTISE_BASE_URL=http://ada2:7860

# Images service (OpenAI Images shim)
# stub: returns a tiny PNG (no GPU/backends required)
# invokeai_queue: proxies to an InvokeAI instance via INVOKEAI_BASE_URL
IMAGES_SHIM_MODE=stub

# Only used when IMAGES_SHIM_MODE=invokeai_queue.
# Set IMAGES_SHIM_INVOKEAI_BASE_URL when the images shim should call a local
# upstream (for example http://invokeai:9090) while the gateway advertises a
# host-routable INVOKEAI_BASE_URL such as http://ada2:9090.
IMAGES_SHIM_INVOKEAI_BASE_URL=http://invokeai:9090
INVOKEAI_BASE_URL=http://invokeai:9090
INVOKEAI_ADVERTISE_BASE_URL=http://ada2:9090
SDXL_TURBO_BASE_URL=http://sdxl-turbo:9050
SDXL_TURBO_ADVERTISE_BASE_URL=http://ada2:9050
LIGHTON_OCR_API_BASE_URL=http://lighton-ocr:9155
LIGHTON_OCR_ADVERTISE_BASE_URL=http://ada2:9155
PERSONAPLEX_BASE_URL=http://personaplex:9160
PERSONAPLEX_ADVERTISE_BASE_URL=http://ada2:9160
FOLLOWYOURCANVAS_BASE_URL=http://followyourcanvas:9165
FOLLOWYOURCANVAS_ADVERTISE_BASE_URL=http://ada2:9165
SKYREELS_V2_BASE_URL=http://skyreels-v2:9180
SKYREELS_V2_ADVERTISE_BASE_URL=http://ada2:9180
HEARTMULA_BASE_URL=http://heartmula:9185
HEARTMULA_ADVERTISE_BASE_URL=http://ada2:9185
DISABLED_BACKEND_CLASSES=
MEDIAMTX_ADVERTISE_BASE_URL=http://ai1:8888
MEDIAMTX_API_ADVERTISE_URL=http://ai1:9997
MEDIAMTX_WEBRTC_ADDITIONAL_HOSTS=ai1
MEDIAMTX_AUTH_METHOD=internal
MEDIAMTX_ENABLE_METRICS=no

# Optional GPU service runtime configuration
INVOKEAI_IMAGE=ghcr.io/invoke-ai/invokeai
SDXL_TURBO_MODEL_ID=stabilityai/sdxl-turbo
SDXL_TURBO_DEVICE=cuda
SDXL_TURBO_DTYPE=float16
SDXL_TURBO_ENABLE_MODEL_CPU_OFFLOAD=false
SDXL_TURBO_ENABLE_SEQUENTIAL_CPU_OFFLOAD=false
SDXL_TURBO_ENABLE_VAE_SLICING=false
LIGHTON_OCR_MODEL_ID=lightonai/LightOnOCR-2-1B
LIGHTON_OCR_RUN_COMMAND=python /app/app/run_lighton_ocr.py
LIGHTON_OCR_DEVICE=auto
PERSONAPLEX_MODEL=personaplex
PERSONAPLEX_REPO_URL=https://github.com/NVIDIA/personaplex
PERSONAPLEX_REPO_REF=
PERSONAPLEX_UPDATE_ON_START=false
FYC_REPO_URL=https://github.com/mayuelala/FollowYourCanvas.git
FYC_REPO_REF=
FYC_UPDATE_ON_START=false
SKYREELS_REPO_URL=https://github.com/SkyworkAI/SkyReels-V2
SKYREELS_REPO_REF=
SKYREELS_UPDATE_ON_START=false
HEARTMULA_REPO_URL=https://github.com/HeartMuLa/heartlib.git
HEARTMULA_REPO_REF=
HEARTMULA_UPDATE_ON_START=false

# ===== Resource Configuration =====

# Enable GPU support (requires NVIDIA Docker runtime for vLLM/image services)
# Set to 'false' to run CPU-only
ENABLE_GPU=true

# Memory limits (optional)
# GATEWAY_MEMORY_LIMIT=2g
# VLLM_MEMORY_LIMIT=16g
# IMAGES_MEMORY_LIMIT=16g

# ===== Service Profiles =====

# Docker Compose profiles to enable
# Default: Core stack uses gateway + vllm + etcd
# Options: full, images, audio
# 
# Examples:
#   COMPOSE_PROFILES=full          # All services
#   COMPOSE_PROFILES=images,audio  # Gateway + vLLM + Images + TTS
#
COMPOSE_PROFILES=

# ===== Advanced Configuration =====

# Enable/disable metrics collection
METRICS_ENABLED=true

# Router configuration
DEFAULT_BACKEND=local_mlx
EMBEDDINGS_BACKEND=local_vllm_embeddings
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
# Gateway media defaults
# - Keep IMAGES_BACKEND_CLASS pointed at your preferred image service.
# - Use local_mlx if your native MLX config exposes image-generation/image-edit models.
IMAGES_BACKEND_CLASS=gpu_heavy
TRANSCRIPTION_BACKEND_CLASS=local_mlx
TRANSCRIPTION_MODEL=
ROUTER_ENABLE_POLICY=true

# Multi-backend coordinator
COORDINATOR_DEFAULT_PARTICIPANTS=default
COORDINATOR_DEFAULT_SYNTHESIZER=default
COORDINATOR_INCLUDE_VISION_ON_MEDIA=true
# When true, code-shaped requests add the `coder` alias as an extra technical pass.
COORDINATOR_INCLUDE_CODER_ON_CODE=true

# Memory v2 features
MEMORY_V2_ENABLED=true

# ===== Tool Bus =====

# Tool bus logs (persisted under ./.runtime/gateway/data)
TOOLS_LOG_MODE=ndjson
TOOLS_LOG_PATH=/var/lib/gateway/data/tools/invocations.jsonl
TOOLS_LOG_DIR=/var/lib/gateway/data/tools

# Tools working directory (inside container)
TOOLS_SHELL_CWD=/var/lib/gateway/data/tools_work
TOOLS_SHELL_TIMEOUT_SEC=20

# External tools registry (persisted under ./.runtime/gateway/config)
TOOLS_REGISTRY_PATH=/var/lib/gateway/config/tools_registry.json
TOOLS_REGISTRY_SHA256=

# Safe defaults: keep high-privilege tools off
TOOLS_ALLOW_SHELL=false
TOOLS_ALLOW_FS=false
TOOLS_ALLOW_HTTP_FETCH=false
TOOLS_ALLOW_GIT=false
TOOLS_ALLOW_SYSTEM_INFO=false
TOOLS_ALLOW_MODELS_REFRESH=false
TOOLS_ALLOWLIST=echo,followyourcanvas_generate,heartmula_generate,lighton_ocr,skyreels_generate

# ===== Development Options =====

# Enable hot reload for gateway (development only)
# HOT_RELOAD=true

# Logging level
# LOG_LEVEL=INFO

# ===== Data Persistence =====

# Nexus uses host bind mounts under `./.runtime/` by default.
# - Gateway RW data:   ./.runtime/gateway/data   → /var/lib/gateway/data
# - Gateway RO config: ./.runtime/gateway/config → /var/lib/gateway/config
# - vLLM cache:        ./.runtime/vllm/cache     → /root/.cache/huggingface
# - MLX cache/config:  ./.runtime/mlx/*          → /var/lib/mlx/*
# - Images:            ./.runtime/images/*       → /data
# - TTS:               ./.runtime/tts/data       → /data
# - etcd:              ./.runtime/etcd/data      → /etcd-data

# If you want to relocate persistence outside the repo (recommended for servers),
# update the bind-mount sources in the relevant `docker-compose.*.yml` file.

# Shared TTS reference pool (voice clone prompts and reusable refs)
# Host path used by compose files: ./.runtime/tts_refs
TTS_SHARED_REFS_DIR=/var/lib/tts_refs
LUXTTS_REFS_DIR=/var/lib/luxtts/voices
LUXTTS_SHARED_REFS_DIR=/var/lib/tts_refs
LUXTTS_SYNC_SHARED_REFS=true
LUXTTS_SYNC_OVERWRITE=false
QWEN3_TTS_REFS_DIR=/var/lib/qwen3-tts/voices
QWEN3_TTS_EXPOSE_REF_VOICES=false
QWEN3_TTS_SHARED_REFS_DIR=/var/lib/tts_refs
QWEN3_TTS_SYNC_SHARED_REFS=true
QWEN3_TTS_SYNC_OVERWRITE=false



# ===== TTS (Pocket TTS shim) =====

# Gateway backend target (containerized default)
POCKET_TTS_BASE_URL=http://tts:9940
POCKET_TTS_ADVERTISE_BASE_URL=http://ai1:9940

# Backend selection: auto | python | command
POCKET_TTS_BACKEND=auto

# Default hints
POCKET_TTS_MODEL_NAME=pocket-tts
POCKET_TTS_MODEL_PATH=
POCKET_TTS_VOICE=alba
POCKET_TTS_REFS_DIR=/var/lib/tts_refs
POCKET_TTS_EXPOSE_REF_VOICES=false

# Command backend (used when POCKET_TTS_BACKEND=command or when python import fails)
POCKET_TTS_COMMAND=pocket-tts

# Hugging Face auth/cache (used by Pocket/Lux/Qwen downloads when required)
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
HF_HOME=/var/lib/huggingface


# ===== TTS (LuxTTS shim) =====

# Gateway backend target (containerized default)
LUXTTS_BASE_URL=http://luxtts:9170
LUXTTS_ADVERTISE_BASE_URL=http://ai1:9170

# Runtime/model identifiers
LUXTTS_MODEL=luxtts
LUXTTS_OUTPUT_FORMAT=wav

# Configure ONE mode for readiness:
# 1) Proxy mode (recommended)
LUXTTS_UPSTREAM_BASE_URL=
LUXTTS_UPSTREAM_ENDPOINT=/v1/audio/speech

# 2) Subprocess mode
LUXTTS_RUN_COMMAND=python /app/app/scripts/run_luxtts.py
LUXTTS_WORKDIR=/app

LUXTTS_TIMEOUT_SEC=120
LUXTTS_READYZ_TIMEOUT_SEC=20

# Optional: map OpenAI voice names to prompt files directly
# LUXTTS_VOICE_MAP_JSON={"alloy":"/var/lib/luxtts/voices/alice.wav"}


# ===== TTS (Qwen3-TTS shim) =====

# Gateway backend target (containerized default)
QWEN3_TTS_BASE_URL=http://qwen3-tts:9175
QWEN3_TTS_ADVERTISE_BASE_URL=http://ai1:9175

# Runtime/model identifiers
QWEN3_TTS_MODEL=qwen3-tts
QWEN3_TTS_OUTPUT_FORMAT=wav

# Configure ONE mode for readiness:
# 1) Proxy mode (recommended)
QWEN3_TTS_UPSTREAM_BASE_URL=
QWEN3_TTS_UPSTREAM_ENDPOINT=/v1/audio/speech

# 2) Subprocess mode
QWEN3_TTS_RUN_COMMAND=python /app/app/scripts/run_qwen3_tts.py
QWEN3_TTS_WORKDIR=/app

QWEN3_TTS_TIMEOUT_SEC=300
QWEN3_TTS_READYZ_TIMEOUT_SEC=20

# Optional: map voice names to explicit reference files for clone-mode fallback
# QWEN3_TTS_REF_MAP_JSON={"alice":"/var/lib/qwen3-tts/voices/alice.wav"}
# Optional default reference transcript when using ref-map/auto-discovered refs
# QWEN3_TTS_REFS_REF_TEXT=
