# Gateway
# SAFE DEFAULT: bind to loopback only.
# If you need LAN access, set GATEWAY_HOST=0.0.0.0 AND use IP allowlisting/firewall rules.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8800
GATEWAY_BEARER_TOKEN=REPLACE_ME

# Observability listener (local HTTP only)
OBSERVABILITY_HOST=127.0.0.1
OBSERVABILITY_PORT=8801

# Backends
OLLAMA_BASE_URL=
MLX_BASE_URL=http://mlx:10240/v1

# Defaults
DEFAULT_BACKEND=local_mlx
OLLAMA_MODEL_DEFAULT=qwen3:30b
MLX_MODEL_DEFAULT=mlx-community/gemma-2-2b-it-8bit

IMAGES_HTTP_BASE_URL=http://images:7860
EMBEDDINGS_BACKEND=local_mlx
# Leave empty to use a provider-aware default:
# - Ollama -> nomic-embed-text
# - MLX -> the configured/default MLX alias model
EMBEDDINGS_MODEL=

# Memory
MEMORY_ENABLED=true
MEMORY_TOP_K=6
MEMORY_MIN_SIM=0.25
MEMORY_MAX_CHARS=6000
