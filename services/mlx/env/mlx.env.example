# MLX service configuration (native macOS launchd service)
MLX_PORT=10240
MLX_HOST=0.0.0.0
MLX_MODEL_PATH=mlx-community/Qwen2.5-7B-Instruct-4bit
MLX_MODEL_TYPE=lm
# Optional cache roots. Point these at a larger volume if /var/lib/mlx is space-constrained.
XDG_CACHE_HOME=/var/lib/mlx/cache
HF_HOME=/var/lib/mlx/cache/huggingface
# Optional: path to an mlx-openai-server config YAML on the MLX host.
# Recommended location: /var/lib/mlx/config/config.yaml
# When set, the service launches in config mode and ignores MLX_MODEL_PATH /
# MLX_MODEL_TYPE at startup.
MLX_CONFIG_PATH=/var/lib/mlx/config/config.yaml
# Prefetch Hugging Face model repos before (re)starting the native MLX service.
PREFETCH_BEFORE_START=1
# Optional Hugging Face auth for higher rate limits / gated repos.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
