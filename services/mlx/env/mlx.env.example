# MLX service configuration (native macOS launchd service)
MLX_PORT=10240
MLX_HOST=0.0.0.0
MLX_MODEL_PATH=mlx-community/gemma-2-2b-it-8bit
MLX_MODEL_TYPE=lm
# Optional: path to an mlx-openai-server config YAML on the MLX host.
# Recommended location: /var/lib/mlx/config/config.yaml
# When set, the service launches in config mode and ignores MLX_MODEL_PATH /
# MLX_MODEL_TYPE at startup.
MLX_CONFIG_PATH=
